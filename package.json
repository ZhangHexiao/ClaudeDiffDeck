{
  "name": "diffdeck",
  "displayName": "DiffDeck",
  "description": "Review every file change Claude Code makes — with diffs, risk flags, and one-click git workflows.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "RodneyZhang",
  "icon": "media/icon.png",
  "categories": ["Other", "SCM Providers"],
  "keywords": ["claude", "claude-code", "diff", "review", "git", "ai", "code-review"],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhangHexiao/ClaudeDiffDeck"
  },
  "homepage": "https://github.com/ZhangHexiao/ClaudeDiffDeck#readme",
  "bugs": {
    "url": "https://github.com/ZhangHexiao/ClaudeDiffDeck/issues"
  },
  "engines": { "vscode": "^1.85.0" },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:claudeReview.panel",
    "workspaceContains:.claude"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeReview",
          "title": "DiffDeck",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeReview": [
        {
          "id": "claudeReview.panel",
          "name": "Pending Review",
          "type": "webview"
        }
      ]
    },
    "commands": [
      { "command": "claudeReview.installHook", "title": "DiffDeck: Install Hook" },
      { "command": "claudeReview.clearBatches", "title": "DiffDeck: Clear All" },
      { "command": "claudeReview.refresh", "title": "DiffDeck: Refresh" },
      { "command": "claudeReview.moveToRightSidebar", "title": "DiffDeck: Move to Right Sidebar" },
      { "command": "claudeReview.gitStart", "title": "DiffDeck: Start (Branch + Draft PR)" },
      { "command": "claudeReview.gitSave", "title": "DiffDeck: Save to Remote" },
      { "command": "claudeReview.gitReReview", "title": "DiffDeck: Re-request Review" }
    ],
    "configuration": {
      "title": "DiffDeck",
      "properties": {
        "diffDeck.riskyGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "Additional glob patterns to flag as **HIGH** risk. Example: `src/core/**`, `src/auth/**`, `**/migrations/**`"
        },
        "diffDeck.largeDeletionThreshold": {
          "type": "number",
          "default": 50,
          "markdownDescription": "Files with more deleted lines than this threshold are flagged as **HIGH** risk."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js && vsce package"
  },
  "dependencies": {
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/diff": "^5.2.0",
    "typescript": "^5.4.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.24.0"
  }
}
